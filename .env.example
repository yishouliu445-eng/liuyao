# ====================================
# Liuyao v2.0 Environment Variables
# ====================================
# 复制本文件为 .env 后填入真实值，.env 已被 .gitignore 排除

# --- Database ---
DB_USER=liuyao
DB_PASSWORD=          # 必填，本地开发可设置任意值如 liuyao_dev

# --- LLM (DashScope / OpenAI compatible) ---
LLM_ENABLED=true
LLM_API_KEY=          # 必填，DashScope API Key 或 OpenAI API Key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
LLM_FOLLOWUP_MODEL=qwen-turbo
LLM_TIMEOUT_MS=15000
LLM_MAX_TOKENS=1500
LLM_TEMPERATURE=0.5

# --- App ---
SERVER_PORT=8080
SESSION_API_ENABLED=true
ORCHESTRATED_ANALYSIS=true

# --- Embedding (Worker 使用) ---
DASHSCOPE_API_KEY=    # 必填（或与 LLM_API_KEY 相同）
EMBEDDING_PROVIDER=dashscope
LIUYAO_EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=
EMBEDDING_BASE_URL=
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_BATCH_SIZE=16
VECTOR_STORE_DIM=1024
WORKER_ID=python-worker-1
POLL_INTERVAL_SECONDS=5

# --- Optional ---
APP_PORT=8080
H5_PORT=3000
DB_PORT=5433
PROMPT_VERSION=v1
