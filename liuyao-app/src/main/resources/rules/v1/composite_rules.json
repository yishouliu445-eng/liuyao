{
  "rules": [
    {
      "id": "R016",
      "name": "多动爻",
      "category": "COMPOSITE",
      "priority": 60,
      "enabled": true,
      "condition": {
        "target": "MOVING_COUNT",
        "operator": "GREATER_THAN",
        "value": 3
      },
      "effect": {
        "score": -1,
        "tags": [
          "局势混乱"
        ],
        "conclusionHints": [
          "动爻过多，局势较乱，结果反复。"
        ]
      },
      "description": "动爻数量过多时，局势不稳。"
    },
    {
      "id": "R019",
      "name": "用神旺且世旺",
      "category": "COMPOSITE",
      "priority": 61,
      "enabled": true,
      "condition": {
        "allOf": [
          {
            "target": "YONGSHEN_STATE",
            "operator": "EQUALS",
            "value": "STRONG"
          },
          {
            "target": "SHI_STATE",
            "operator": "EQUALS",
            "value": "STRONG"
          }
        ]
      },
      "effect": {
        "score": 3,
        "tags": [
          "双强"
        ],
        "conclusionHints": [
          "用神与世爻都旺，整体偏吉。"
        ]
      },
      "description": "用神和世爻都旺。"
    },
    {
      "id": "R020",
      "name": "用神弱且世弱",
      "category": "COMPOSITE",
      "priority": 62,
      "enabled": true,
      "condition": {
        "allOf": [
          {
            "target": "YONGSHEN_STATE",
            "operator": "EQUALS",
            "value": "WEAK"
          },
          {
            "target": "SHI_STATE",
            "operator": "EQUALS",
            "value": "WEAK"
          }
        ]
      },
      "effect": {
        "score": -3,
        "tags": [
          "双弱"
        ],
        "conclusionHints": [
          "用神和世爻都弱，整体偏凶。"
        ]
      },
      "description": "用神和世爻都弱。"
    },
    {
      "id": "R022",
      "name": "主用神贴近世爻",
      "category": "COMPOSITE",
      "priority": 63,
      "enabled": true,
      "condition": {
        "target": "USE_GOD_DISTANCE_TO_SHI",
        "operator": "LESS_THAN_OR_EQUALS",
        "value": 1
      },
      "effect": {
        "score": 1,
        "tags": [
          "贴近日身"
        ],
        "conclusionHints": [
          "主用神贴近世爻，说明事情与自己关联更直接。"
        ]
      },
      "description": "主用神与世爻距离较近。"
    },
    {
      "id": "R041",
      "name": "世应有情但动变扰用",
      "category": "COMPOSITE",
      "priority": 64,
      "enabled": true,
      "condition": {
        "allOf": [
          {
            "target": "SHI_YING_RELATION",
            "operator": "IN",
            "value": [
              "应生世",
              "世生应"
            ]
          },
          {
            "anyOf": [
              {
                "target": "HAS_MOVING_KE_USE_GOD",
                "operator": "IS_TRUE"
              },
              {
                "target": "HAS_CHANGED_KE_USE_GOD",
                "operator": "IS_TRUE"
              },
              {
                "target": "HAS_MOVING_CHONG_USE_GOD",
                "operator": "IS_TRUE"
              },
              {
                "target": "HAS_MOVING_AFFECT_SHI",
                "operator": "IS_TRUE"
              }
            ]
          }
        ]
      },
      "effect": {
        "score": -1,
        "tags": [
          "助中有扰"
        ],
        "conclusionHints": [
          "世应关系虽有助力，但动变已经开始扰动主线，不能只按表面和气论吉。"
        ]
      },
      "description": "世应偏和时，仍需防动变对主线的干扰。"
    },
    {
      "id": "R042",
      "name": "世应相克但动变扶用",
      "category": "COMPOSITE",
      "priority": 65,
      "enabled": true,
      "condition": {
        "allOf": [
          {
            "target": "SHI_YING_RELATION",
            "operator": "IN",
            "value": [
              "应克世",
              "世克应"
            ]
          },
          {
            "anyOf": [
              {
                "target": "HAS_MOVING_SHENG_USE_GOD",
                "operator": "IS_TRUE"
              },
              {
                "target": "HAS_CHANGED_SHENG_USE_GOD",
                "operator": "IS_TRUE"
              },
              {
                "target": "USE_GOD_ADVANCE",
                "operator": "IS_TRUE"
              }
            ]
          }
        ]
      },
      "effect": {
        "score": 1,
        "tags": [
          "逆势有机"
        ],
        "conclusionHints": [
          "虽然世应相克，但动变并未完全背离主用神，局中仍留有转机。"
        ]
      },
      "description": "世应虽相克，动变仍可能给主线留下回旋空间。"
    }
  ]
}
