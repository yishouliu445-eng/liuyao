    {
      "id": "R017",
      "ruleCode": "MOVING_LINE_AFFECT_USE_GOD",
      "name": "用神动而生世",
      "category": "MOVING_CHANGE",
      "priority": 33,
      "enabled": true,
      "effect": {
        "conclusionHints": ["动爻与变爻会改变用神后续走势。"]
      },
      "description": "动爻和变爻对用神产生影响。"
