    {
      "id": "R011",
      "name": "世爻空亡",
      "category": "SHI_STATE",
      "priority": 37,
      "enabled": true,
      "condition": {
        "target": "SHI_EMPTY",
        "operator": "IS_TRUE"
      },
      "effect": {
        "score": -2,
        "tags": ["心虚", "落空"],
