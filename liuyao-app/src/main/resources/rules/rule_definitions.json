    {
      "id": "R018",
      "name": "用神动而化退",
      "category": "MOVING_CHANGE",
      "priority": 34,
      "enabled": true,
      "condition": {
        "target": "USE_GOD_RETREAT",
        "operator": "IS_TRUE"
      },
      "effect": {
        "score": -2,
        "tags": ["后劲不足"],
        "conclusionHints": ["用神虽然发动，但后续转衰或转出他亲，后劲不足。"]
      },
      "description": "用神发动后转弱或转出他亲。"
    },
    {
      "id": "R016",
      "name": "多动爻",
      "category": "COMPOSITE",
      "priority": 60,
      "enabled": true,
      "condition": {
        "target": "MOVING_COUNT",
        "operator": "GREATER_THAN",
        "value": 3
      },
      "effect": {
        "score": -1,
        "tags": ["局势混乱"],
        "conclusionHints": ["动爻过多，局势较乱，结果反复。"]
      },
      "description": "动爻数量过多时，局势不稳。"
    },
    {
      "id": "R019",
      "name": "用神旺且世旺",
      "category": "COMPOSITE",
      "priority": 61,
      "enabled": true,
      "condition": {
        "allOf": [
          {"target": "YONGSHEN_STATE", "operator": "EQUALS", "value": "STRONG"},
          {"target": "SHI_STATE", "operator": "EQUALS", "value": "STRONG"}
