      "description": "用神和世爻都旺。"
    },
    {
      "id": "R020",
      "name": "用神弱且世弱",
      "category": "COMPOSITE",
      "priority": 62,
      "enabled": true,
      "condition": {
        "allOf": [
          {"target": "YONGSHEN_STATE", "operator": "EQUALS", "value": "WEAK"},
          {"target": "SHI_STATE", "operator": "EQUALS", "value": "WEAK"}
