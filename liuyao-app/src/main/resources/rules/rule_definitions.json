      "effect": {
        "score": 1,
        "tags": ["有接近", "有机会"],
        "conclusionHints": ["用神合世，说明事情与自己有接近和促成的机会。"]
      },
      "description": "用神与世爻形成六合。"
    },
    {
      "id": "R099",
