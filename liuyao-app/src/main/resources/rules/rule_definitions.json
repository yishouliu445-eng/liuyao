      "name": "用神生世",
      "category": "YONGSHEN_STATE",
      "priority": 27,
      "enabled": true,
      "condition": {
        "target": "USE_GOD_TO_SHI_RELATION",
        "operator": "EQUALS",
        "value": "生"
      },
      "effect": {
        "score": 2,
        "tags": ["有利"],
        "conclusionHints": ["用神生世，说明事情对自己更有帮助。"]
      },
      "description": "用神五行生世爻。"
    },
    {
